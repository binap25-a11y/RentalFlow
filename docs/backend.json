
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User account and role metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["landlord", "tenant"] },
        "phoneNumber": { "type": "string" }
      }
    },
    "Property": {
      "title": "Property",
      "description": "Real estate asset details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "addressLine1": { "type": "string" },
        "city": { "type": "string" },
        "zipCode": { "type": "string" },
        "rentAmount": { "type": "number" },
        "imageUrl": { "type": "string" },
        "imageUrls": { "type": "array", "items": { "type": "string" } },
        "propertyType": { "type": "string" },
        "numberOfBedrooms": { "type": "number" },
        "numberOfBathrooms": { "type": "number" },
        "isOccupied": { "type": "boolean" },
        "tenantIds": { "type": "array", "items": { "type": "string" } },
        "memberIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "PropertyDocument": {
      "title": "PropertyDocument",
      "description": "A shared document in the property vault.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fileName": { "type": "string" },
        "fileUrl": { "type": "string" },
        "documentType": { "type": "string" },
        "propertyId": { "type": "string" },
        "landlordId": { "type": "string" },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "expiryDate": { "type": "string", "format": "date-time" },
        "uploadDate": { "type": "string", "format": "date-time" }
      }
    },
    "MaintenanceRequest": {
      "title": "MaintenanceRequest",
      "description": "Repair and upkeep tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "category": { "type": "string" },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "cost": { "type": "number" },
        "assignedContractorId": { "type": "string" },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "aiTriageNotes": { "type": "string" },
        "aiSuggestions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Inspection": {
      "title": "Inspection",
      "description": "Property compliance audit record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "landlordId": { "type": "string" },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["scheduled", "completed"] },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "healthScore": { "type": "number" },
        "summary": { "type": "string" }
      }
    },
    "EmergencyContact": {
      "title": "EmergencyContact",
      "description": "Service partner or emergency resource contact details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "website": { "type": "string" },
        "category": { "type": "string", "enum": ["standard", "professional"] },
        "propertyId": { "type": "string" },
        "memberIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "RentPayment": {
      "title": "RentPayment",
      "description": "Real-time monthly rent record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "landlordId": { "type": "string" },
        "tenantId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "pending", "overdue"] },
        "month": { "type": "number" },
        "year": { "type": "number" },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "paidAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "User profiles."
    },
    "/properties/{propertyId}": {
      "schema": { "$ref": "#/backend/entities/Property" },
      "description": "Portfolio assets."
    },
    "/maintenanceRequests/{requestId}": {
      "schema": { "$ref": "#/backend/entities/MaintenanceRequest" },
      "description": "Maintenance tracking records."
    },
    "/inspections/{inspectionId}": {
      "schema": { "$ref": "#/backend/entities/Inspection" },
      "description": "Compliance audit records."
    },
    "/emergencyContacts/{contactId}": {
      "schema": { "$ref": "#/backend/entities/EmergencyContact" },
      "description": "Authorized property partners and contractors."
    },
    "/tenantProfiles/{profileId}": {
      "schema": { "type": "object" },
      "description": "Resident assignment records."
    },
    "/documents/{documentId}": {
      "schema": { "$ref": "#/backend/entities/PropertyDocument" },
      "description": "Shared property vault documents."
    },
    "/messages/{messageId}": {
      "schema": { "type": "object" },
      "description": "Secure direct messages."
    },
    "/rentPayments/{paymentId}": {
      "schema": { "$ref": "#/backend/entities/RentPayment" },
      "description": "Real-time monthly rent collection ledger."
    }
  }
}
