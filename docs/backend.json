
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the LeaseLoop application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "role": { "type": "string" }
      },
      "required": ["id", "email", "firstName", "lastName", "role"]
    },
    "Property": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Property",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "landlordId": { "type": "string" },
        "addressLine1": { "type": "string" },
        "city": { "type": "string" },
        "zipCode": { "type": "string" },
        "propertyType": { "type": "string" },
        "numberOfBedrooms": { "type": "number" },
        "numberOfBathrooms": { "type": "number" },
        "description": { "type": "string" },
        "isActive": { "type": "boolean" },
        "memberIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "landlordId", "addressLine1", "city", "zipCode", "isActive"]
    },
    "TenantProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TenantProfile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "landlordId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "leaseStartDate": { "type": "string", "format": "date" },
        "leaseEndDate": { "type": "string", "format": "date" },
        "memberIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "userId", "propertyId", "landlordId"]
    },
    "PropertyDocument": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PropertyDocument",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "landlordId": { "type": "string" },
        "userId": { "type": "string" },
        "fileUrl": { "type": "string", "format": "uri" },
        "fileName": { "type": "string" },
        "documentType": { "type": "string" },
        "uploadDate": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date" },
        "memberIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "propertyId", "landlordId", "fileUrl", "fileName"]
    },
    "MaintenanceRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MaintenanceRequest",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "tenantId": { "type": "string" },
        "landlordId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "object" },
        "memberIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "propertyId", "landlordId", "title", "status"]
    },
    "Inspection": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Inspection",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "landlordId": { "type": "string" },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "findings": { "type": "string" },
        "summary": { "type": "string" },
        "healthScore": { "type": "number" },
        "memberIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "propertyId", "landlordId", "scheduledDate", "status"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/users/{landlordId}/properties/{propertyId}",
        "definition": {
          "entityName": "Property",
          "schema": { "$ref": "#/backend/entities/Property" },
          "description": "Rental properties."
        }
      },
      {
        "path": "/users/{landlordId}/tenantProfiles/{profileId}",
        "definition": {
          "entityName": "TenantProfile",
          "schema": { "$ref": "#/backend/entities/TenantProfile" },
          "description": "Resident associations."
        }
      },
      {
        "path": "/users/{landlordId}/documents/{docId}",
        "definition": {
          "entityName": "PropertyDocument",
          "schema": { "$ref": "#/backend/entities/PropertyDocument" },
          "description": "Portfolio vault."
        }
      },
      {
        "path": "/users/{landlordId}/maintenanceRequests/{requestId}",
        "definition": {
          "entityName": "MaintenanceRequest",
          "schema": { "$ref": "#/backend/entities/MaintenanceRequest" },
          "description": "Issue tracking."
        }
      },
      {
        "path": "/users/{landlordId}/inspections/{inspectionId}",
        "definition": {
          "entityName": "Inspection",
          "schema": { "$ref": "#/backend/entities/Inspection" },
          "description": "Health checks."
        }
      }
    ]
  }
}
