{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User account and role metadata.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["landlord", "tenant"] },
        "phoneNumber": { "type": "string" },
        "plan": { "type": "string", "enum": ["free", "pro"] }
      }
    },
    "Property": {
      "title": "Property",
      "description": "Real estate asset details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "addressLine1": { "type": "string" },
        "city": { "type": "string" },
        "zipCode": { "type": "string" },
        "rentAmount": { "type": "number" },
        "imageUrl": { "type": "string" },
        "imageUrls": { "type": "array", "items": { "type": "string" } },
        "propertyType": { "type": "string" },
        "numberOfBedrooms": { "type": "number" },
        "numberOfBathrooms": { "type": "number" },
        "isOccupied": { "type": "boolean" },
        "landlordId": { "type": "string" },
        "tenantIds": { "type": "array", "items": { "type": "string" } },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "connectivityStatus": { "type": "string" },
        "complianceStatus": { "type": "string" },
        "complianceStatusMap": { "type": "object" }
      }
    },
    "PropertyDocument": {
      "title": "PropertyDocument",
      "description": "A shared document in the property vault.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fileName": { "type": "string" },
        "fileUrl": { "type": "string" },
        "documentType": { "type": "string" },
        "propertyId": { "type": "string" },
        "landlordId": { "type": "string" },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "uploadDate": { "type": "string", "format": "date-time" }
      }
    },
    "MaintenanceRequest": {
      "title": "MaintenanceRequest",
      "description": "Repair and upkeep tracking.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "landlordId": { "type": "string" },
        "tenantId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "category": { "type": "string" },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "cost": { "type": "number" },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "aiTriageNotes": { "type": "string" },
        "aiSuggestions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Inspection": {
      "title": "Inspection",
      "description": "Property compliance audit record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "landlordId": { "type": "string" },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "healthScore": { "type": "number" },
        "summary": { "type": "string" },
        "structuredFindings": { "type": "object" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "Real-time system alert or message.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "recipientId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["grade", "message", "alert"] },
        "href": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" }
    },
    "/properties/{propertyId}": {
      "schema": { "$ref": "#/backend/entities/Property" }
    },
    "/maintenanceRequests/{requestId}": {
      "schema": { "$ref": "#/backend/entities/MaintenanceRequest" }
    },
    "/inspections/{inspectionId}": {
      "schema": { "$ref": "#/backend/entities/Inspection" }
    },
    "/documents/{documentId}": {
      "schema": { "$ref": "#/backend/entities/PropertyDocument" }
    },
    "/notifications/{notificationId}": {
      "schema": { "$ref": "#/backend/entities/Notification" }
    }
  }
}
