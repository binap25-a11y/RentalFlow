
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the RentalFlow application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "role": { "type": "string", "enum": ["landlord", "tenant"] },
        "avatarUrl": { "type": "string", "format": "uri" }
      },
      "required": ["id", "email", "firstName", "lastName", "role"]
    },
    "Property": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Property",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "landlordId": { "type": "string" },
        "addressLine1": { "type": "string" },
        "city": { "type": "string" },
        "zipCode": { "type": "string" },
        "propertyType": { "type": "string" },
        "numberOfBedrooms": { "type": "number" },
        "numberOfBathrooms": { "type": "number" },
        "description": { "type": "string" },
        "isActive": { "type": "boolean" },
        "isOccupied": { "type": "boolean" },
        "tenantIds": { "type": "array", "items": { "type": "string" } },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "rentAmount": { "type": "number" },
        "imageUrl": { "type": "string" },
        "imageUrls": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "landlordId", "addressLine1", "city", "zipCode", "isActive"]
    },
    "EmergencyContact": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "EmergencyContact",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "landlordId": { "type": "string" },
        "propertyId": { "type": "string" },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["id", "landlordId", "name", "role", "phone"]
    },
    "TenantProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TenantProfile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "propertyId": { "type": "string" },
        "landlordId": { "type": "string" },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "leaseStartDate": { "type": "string", "format": "date" },
        "leaseEndDate": { "type": "string", "format": "date" }
      },
      "required": ["id", "userId", "propertyId", "landlordId"]
    },
    "PropertyDocument": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PropertyDocument",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "landlordId": { "type": "string" },
        "userId": { "type": "string" },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "fileUrl": { "type": "string", "format": "uri" },
        "fileName": { "type": "string" },
        "documentType": { "type": "string" },
        "uploadDate": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date" },
        "aiSummary": { "type": "string" }
      },
      "required": ["id", "propertyId", "landlordId", "fileUrl", "fileName"]
    },
    "Message": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "propertyId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "object" },
        "memberIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "senderId", "receiverId", "text", "memberIds"]
    },
    "MaintenanceRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MaintenanceRequest",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "tenantId": { "type": "string" },
        "landlordId": { "type": "string" },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "category": { "type": "string" },
        "aiTriageNotes": { "type": "string" },
        "createdAt": { "type": "object" }
      },
      "required": ["id", "propertyId", "landlordId", "title", "status"]
    },
    "Inspection": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Inspection",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "landlordId": { "type": "string" },
        "memberIds": { "type": "array", "items": { "type": "string" } },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "conductedDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string" },
        "findings": { "type": "string" },
        "summary": { "type": "string" },
        "priorityItems": { "type": "array", "items": { "type": "string" } },
        "healthScore": { "type": "number" }
      },
      "required": ["id", "propertyId", "landlordId", "scheduledDate", "status"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles."
        }
      },
      {
        "path": "/properties/{propertyId}",
        "definition": {
          "entityName": "Property",
          "schema": { "$ref": "#/backend/entities/Property" },
          "description": "Top-level property assets."
        }
      },
      {
        "path": "/emergencyContacts/{contactId}",
        "definition": {
          "entityName": "EmergencyContact",
          "schema": { "$ref": "#/backend/entities/EmergencyContact" },
          "description": "Property emergency contacts."
        }
      },
      {
        "path": "/tenantProfiles/{profileId}",
        "definition": {
          "entityName": "TenantProfile",
          "schema": { "$ref": "#/backend/entities/TenantProfile" },
          "description": "Resident associations."
        }
      },
      {
        "path": "/documents/{docId}",
        "definition": {
          "entityName": "PropertyDocument",
          "schema": { "$ref": "#/backend/entities/PropertyDocument" },
          "description": "Document vault items."
        }
      },
      {
        "path": "/maintenanceRequests/{requestId}",
        "definition": {
          "entityName": "MaintenanceRequest",
          "schema": { "$ref": "#/backend/entities/MaintenanceRequest" },
          "description": "Maintenance tracking records."
        }
      },
      {
        "path": "/inspections/{inspectionId}",
        "definition": {
          "entityName": "Inspection",
          "schema": { "$ref": "#/backend/entities/Inspection" },
          "description": "Property inspection reports."
        }
      },
      {
        "path": "/messages/{messageId}",
        "definition": {
          "entityName": "Message",
          "schema": { "$ref": "#/backend/entities/Message" },
          "description": "Platform messaging records."
        }
      }
    ]
  }
}
