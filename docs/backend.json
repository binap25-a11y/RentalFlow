
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores core user information and role within RentalFlow.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["landlord", "tenant"] },
        "externalAuthId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role", "externalAuthId", "createdAt", "updatedAt"]
    },
    "Property": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Property",
      "type": "object",
      "description": "Represents a rental property managed by a landlord.",
      "properties": {
        "id": { "type": "string" },
        "landlordId": { "type": "string" },
        "addressLine1": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "zipCode": { "type": "string" },
        "description": { "type": "string" },
        "numberOfBedrooms": { "type": "number" },
        "numberOfBathrooms": { "type": "number" },
        "rentAmount": { "type": "number" },
        "isOccupied": { "type": "boolean" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "landlordId", "addressLine1", "city", "state", "zipCode", "description", "rentAmount", "isOccupied", "createdAt", "updatedAt"]
    },
    "TenantProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TenantProfile",
      "type": "object",
      "description": "Detailed profile information for a tenant.",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "propertyId": { "type": "string" },
        "landlordId": { "type": "string" },
        "userProfileId": { "type": "string" },
        "leaseStartDate": { "type": "string", "format": "date" },
        "leaseEndDate": { "type": "string", "format": "date" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "firstName", "lastName", "email", "propertyId", "landlordId", "createdAt", "updatedAt"]
    },
    "Document": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Document",
      "type": "object",
      "description": "Stores metadata about files uploaded to a secure storage bucket.",
      "properties": {
        "id": { "type": "string" },
        "fileName": { "type": "string" },
        "fileUrl": { "type": "string", "format": "uri" },
        "documentType": { "type": "string" },
        "description": { "type": "string" },
        "propertyId": { "type": "string" },
        "expiryDate": { "type": "string", "format": "date" },
        "userId": { "type": "string", "description": "The user who owns or is allowed to view this document." },
        "landlordId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fileName", "fileUrl", "documentType", "userId", "landlordId", "createdAt"]
    },
    "MaintenanceRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MaintenanceRequest",
      "type": "object",
      "description": "Records details of maintenance issues.",
      "properties": {
        "id": { "type": "string" },
        "propertyId": { "type": "string" },
        "landlordId": { "type": "string" },
        "reportedByUserId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string" },
        "category": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "aiTriageNotes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "propertyId", "landlordId", "reportedByUserId", "title", "description", "status", "priority", "category", "submittedAt", "createdAt", "updatedAt"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Stores core user profiles."
        }
      },
      {
        "path": "/properties/{propertyId}",
        "definition": {
          "entityName": "Property",
          "schema": { "$ref": "#/backend/entities/Property" },
          "description": "Stores rental property details."
        }
      },
      {
        "path": "/tenants/{tenantId}",
        "definition": {
          "entityName": "TenantProfile",
          "schema": { "$ref": "#/backend/entities/TenantProfile" },
          "description": "Contains detailed profile information for tenants."
        }
      },
      {
        "path": "/maintenanceRequests/{requestId}",
        "definition": {
          "entityName": "MaintenanceRequest",
          "schema": { "$ref": "#/backend/entities/MaintenanceRequest" },
          "description": "Records maintenance requests."
        }
      },
      {
        "path": "/documents/{documentId}",
        "definition": {
          "entityName": "Document",
          "schema": { "$ref": "#/backend/entities/Document" },
          "description": "Stores metadata for various uploaded files."
        }
      }
    ]
  }
}
