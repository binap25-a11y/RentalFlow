rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION GROUP RULES ---
    // These rules are required for collectionGroup() queries used in dashboards.
    // They match the collection name regardless of its position in the path.

    match /{path=**}/properties/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource == null || resource.data.landlordId == request.auth.uid
      );
    }

    match /{path=**}/documents/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        resource == null || 
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
      allow create, update, delete: if isSignedIn() && (
        resource == null || resource.data.landlordId == request.auth.uid
      );
    }

    match /{path=**}/maintenanceRequests/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        resource == null || 
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource == null || 
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
    }

    match /{path=**}/inspections/{id} {
      allow list, get: if isSignedIn();
      allow create, update, delete: if isSignedIn() && (
        resource == null || resource.data.landlordId == request.auth.uid
      );
    }

    match /{path=**}/tenantProfiles/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        resource == null || 
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
      allow create, update, delete: if isSignedIn() && (
        resource == null || resource.data.landlordId == request.auth.uid
      );
    }

    match /{path=**}/images/{id} {
      allow list, get: if isSignedIn();
      allow create, delete: if isSignedIn() && (
        resource == null || resource.data.landlordId == request.auth.uid
      );
    }

    match /{path=**}/emergencyContactSheets/{id} {
      allow list, get, create: if isSignedIn();
    }

    // --- PATH-SPECIFIC RULES ---
    // Rules for direct access to user profiles and their subcollections.
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}