rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // User profiles: Only the owner can read/write
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Landlord-owned data hierarchy
      match /properties/{propertyId} {
        function isOwner() {
          return isSignedIn() && request.auth.uid == userId;
        }

        // Landlords can manage their own properties
        // Tenants can read if they are in the members map
        allow read: if isOwner() || (resource != null && resource.data.members != null && resource.data.members[request.auth.uid] != null);
        allow write: if isOwner();

        // Sub-collections under a property
        match /{allSubcollections=**} {
          allow read, write: if isOwner();
          allow read: if isSignedIn() && (
            (resource != null && resource.data.userId == request.auth.uid) ||
            (resource != null && resource.data.tenantId == request.auth.uid) ||
            (resource != null && resource.data.members != null && resource.data.members[request.auth.uid] != null) ||
            (resource != null && resource.data.landlordId == request.auth.uid)
          );
        }
      }
    }

    // Collection Group rules for cross-property queries (Dashboard/Management/Tenant View)
    match /{path=**}/properties/{id} {
      allow list: if isSignedIn() && (
        (resource != null && resource.data.landlordId == request.auth.uid) || 
        (resource != null && resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
    match /{path=**}/maintenanceRequests/{id} {
      allow list: if isSignedIn() && (
        (resource != null && (resource.data.landlordId == request.auth.uid || resource.data.tenantId == request.auth.uid))
      );
    }
    match /{path=**}/inspections/{id} {
      allow list: if isSignedIn() && (
        (resource != null && (resource.data.landlordId == request.auth.uid || (resource.data.members != null && resource.data.members[request.auth.uid] != null)))
      );
    }
    match /{path=**}/tenantProfiles/{id} {
      allow list: if isSignedIn() && (
        (resource != null && (resource.data.landlordId == request.auth.uid || resource.data.userId == request.auth.uid))
      );
    }
    match /{path=**}/documents/{id} {
      allow list: if isSignedIn() && (
        (resource != null && (
          resource.data.landlordId == request.auth.uid || 
          resource.data.userId == request.auth.uid ||
          (resource.data.members != null && resource.data.members[request.auth.uid] != null)
        ))
      );
    }
    match /{path=**}/emergencyContacts/{id} {
      allow list: if isSignedIn() && (
        (resource != null && (
          resource.data.landlordId == request.auth.uid || 
          (resource.data.members != null && resource.data.members[request.auth.uid] != null)
        ))
      );
    }
  }
}