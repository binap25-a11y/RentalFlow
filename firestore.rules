
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION GROUP RULES (MUST BE TOP-LEVEL FOR QUERIES) ---
    // These rules allow list operations (queries) across the entire database
    // while restricting individual document access (get) to authorized users.
    
    match /{path=**}/properties/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }

    match /{path=**}/maintenanceRequests/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
    }

    match /{path=**}/inspections/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }

    match /{path=**}/tenantProfiles/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
    }

    match /{path=**}/documents/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }

    match /{path=**}/images/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }

    match /{path=**}/emergencyContactSheets/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }

    // --- PATH-SPECIFIC RULES ---

    // Standard User Profile Access
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Recursive catch-all for path-based access (mostly for landlords)
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
