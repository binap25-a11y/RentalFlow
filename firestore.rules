rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- COLLECTION GROUP RULES ---
    // Specifically optimized for portfolio-wide listings (Dashboards)
    match /{path=**}/properties/{id} {
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    match /{path=**}/documents/{id} {
      allow read, list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        resource.data.userId == request.auth.uid ||
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow create, update, delete: if isSignedIn() && (
        request.resource.data.landlordId == request.auth.uid ||
        request.resource.data.userId == request.auth.uid
      );
    }

    match /{path=**}/maintenanceRequests/{id} {
      allow read, list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        resource.data.tenantId == request.auth.uid
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        resource.data.tenantId == request.auth.uid
      );
    }

    match /{path=**}/inspections/{id} {
      allow read, list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow create, update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    match /{path=**}/tenantProfiles/{id} {
      allow read, list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        resource.data.userId == request.auth.uid
      );
      allow create, update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- PATH-SPECIFIC RULES (Owner Direct Access) ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}