
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // --- Property Assets ---
    match /properties/{id} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.landlordId || 
        (resource.data.tenantIds != null && request.auth.uid in resource.data.tenantIds) ||
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
    }

    // --- Resident Profiles ---
    match /tenantProfiles/{id} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.landlordId || 
        request.auth.uid == resource.data.userId ||
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
    }

    // --- Real-Time Notifications ---
    match /notifications/{id} {
      allow create: if isSignedIn();
      allow read, update: if isSignedIn() && (
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds) ||
        request.auth.uid == resource.data.userId
      );
    }

    // --- Maintenance Ledger ---
    match /maintenanceRequests/{id} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.landlordId || 
        request.auth.uid == resource.data.tenantId ||
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
    }

    // --- Document Vault ---
    match /documents/{id} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.landlordId || 
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
    }

    // --- Secure Messaging ---
    match /messages/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.senderId || 
        request.auth.uid == resource.data.receiverId ||
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.senderId;
    }

    // --- Compliance Audits ---
    match /inspections/{id} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.landlordId || 
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
    }

    // --- Support Directory ---
    match /emergencyContacts/{id} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.landlordId || 
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
    }
  }
}
