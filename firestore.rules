rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // User profiles: Only the owner can read/write
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Hierarchical access for Landlords
      match /properties/{propertyId} {
        
        function isOwner() {
          return isSignedIn() && request.auth.uid == userId;
        }

        // Allow listing properties collection and reading/writing individual properties
        allow list: if isOwner();
        allow get: if isSignedIn() && (isOwner() || (resource != null && resource.data.members != null && resource.data.members[request.auth.uid] != null));
        allow write: if isOwner();

        // Sub-collections under a property
        match /{allSubcollections=**} {
          allow read, write: if isOwner();
          allow list: if isOwner();
        }

        // Specific tenant access for sub-collections based on members or specific fields
        match /tenantProfiles/{id} { 
          allow read: if isSignedIn() && (isOwner() || resource.data.userId == request.auth.uid);
        }
        match /images/{id} { 
          allow read: if isSignedIn() && (isOwner() || (resource != null && resource.data.members != null && resource.data.members[request.auth.uid] != null)); 
        }
        match /documents/{id} { 
          allow read: if isSignedIn() && (isOwner() || resource.data.userId == request.auth.uid || (resource != null && resource.data.members != null && resource.data.members[request.auth.uid] != null)); 
        }
        match /inspections/{id} { 
          allow read: if isSignedIn() && (isOwner() || (resource != null && resource.data.members != null && resource.data.members[request.auth.uid] != null)); 
        }
        match /maintenanceRequests/{id} { 
          allow read, update, delete: if isSignedIn() && (isOwner() || resource.data.tenantId == request.auth.uid);
          allow create: if isSignedIn();
        }
      }
    }

    // Collection Group rules for cross-property queries
    match /{path=**}/properties/{id} {
      allow list: if isSignedIn() && (
        (resource != null && resource.data.landlordId == request.auth.uid) || 
        (resource != null && resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
    match /{path=**}/maintenanceRequests/{id} {
      allow list: if isSignedIn() && (
        (resource != null && resource.data.landlordId == request.auth.uid) || 
        (resource != null && resource.data.tenantId == request.auth.uid)
      );
    }
    match /{path=**}/inspections/{id} {
      allow list: if isSignedIn() && (
        (resource != null && resource.data.landlordId == request.auth.uid) || 
        (resource != null && resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
    match /{path=**}/tenantProfiles/{id} {
      allow list: if isSignedIn() && (
        (resource != null && resource.data.landlordId == request.auth.uid) || 
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }
    match /{path=**}/documents/{id} {
      allow list: if isSignedIn() && (
        (resource != null && resource.data.landlordId == request.auth.uid) || 
        (resource != null && resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
  }
}