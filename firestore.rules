
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(landlordId) {
      return isSignedIn() && request.auth.uid == landlordId;
    }

    function isMember() {
      return isSignedIn() && (
        (resource != null && resource.data.memberIds != null && request.auth.uid in resource.data.memberIds) ||
        (request.resource != null && request.resource.data.memberIds != null && request.auth.uid in request.resource.data.memberIds)
      );
    }

    // --- COLLECTION GROUP RULES ---
    // Specifically optimized for Landlord and Resident dashboard queries
    
    match /{path=**}/properties/{id} {
      allow list: if isSignedIn() && (resource.data.landlordId == request.auth.uid || isMember());
      allow read: if isSignedIn() && (resource.data.landlordId == request.auth.uid || isMember());
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    match /{path=**}/tenantProfiles/{id} {
      allow list: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.userId == request.auth.uid || isMember());
      allow read: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.userId == request.auth.uid || isMember());
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.userId == request.auth.uid);
    }

    match /{path=**}/documents/{id} {
      allow list: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.userId == request.auth.uid || isMember());
      allow read: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.userId == request.auth.uid || isMember());
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.userId == request.auth.uid);
    }

    match /{path=**}/maintenanceRequests/{id} {
      allow list: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.tenantId == request.auth.uid || isMember());
      allow read: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.tenantId == request.auth.uid || isMember());
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.tenantId == request.auth.uid);
    }

    match /{path=**}/inspections/{id} {
      allow list: if isSignedIn() && (resource.data.landlordId == request.auth.uid || isMember());
      allow read: if isSignedIn() && (resource.data.landlordId == request.auth.uid || isMember());
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // --- PATH-SPECIFIC RULES (Owner Direct Access) ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
