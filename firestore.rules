rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMember(data) {
      return isSignedIn() && (
        data.landlordId == request.auth.uid || 
        data.userId == request.auth.uid ||
        data.tenantId == request.auth.uid ||
        (data.memberIds != null && request.auth.uid in data.memberIds)
      );
    }

    // User profiles are private
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Properties: Secured by membership or landlordId
    match /properties/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.tenantIds != null && request.auth.uid in resource.data.tenantIds) ||
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow get: if isMember(resource.data);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // Tenant Profiles: Optimized for explicit Landlord and Resident access
    match /tenantProfiles/{id} {
      allow read: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // Documents: Secured for listing via landlordId or membership
    match /documents/{id} {
      allow read: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.userId == request.auth.uid || (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds));
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // Maintenance: Secured by membership
    match /maintenanceRequests/{id} {
      allow read: if isMember(resource.data);
      allow create: if isSignedIn();
      allow update, delete: if isMember(resource.data);
    }

    // Inspections: Landlords and members
    match /inspections/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow get: if isMember(resource.data);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }
  }
}