
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION GROUP RULES ---
    // Required for portfolio-wide scans and resident profile lookups

    match /{path=**}/tenants/{tenantId} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userProfileId == request.auth.uid
      );
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userProfileId == request.auth.uid ||
        tenantId == request.auth.uid
      );
    }

    match /{path=**}/maintenanceRequests/{requestId} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.reportedByUserId == request.auth.uid
      );
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.reportedByUserId == request.auth.uid
      );
    }

    // --- HIERARCHICAL RULES ---

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /properties/{propertyId} {
        allow read, write: if isOwner(userId);
        
        // Allow residents to see their own property details
        allow get: if isSignedIn() && (
          isOwner(userId) || 
          exists(/databases/$(database)/documents/users/$(userId)/properties/$(propertyId)/tenants/$(request.auth.uid))
        );

        // 🔥 TENANTS SUBCOLLECTION (CRITICAL)
        match /tenants/{tenantId} {
          allow read, write: if isOwner(userId);
        }

        match /maintenanceRequests/{requestId} {
          allow read, write: if isOwner(userId);
          allow create: if isSignedIn() && request.resource.data.reportedByUserId == request.auth.uid;
          allow update: if isSignedIn() && (
            isOwner(userId) || 
            resource.data.reportedByUserId == request.auth.uid
          );
        }

        match /emergencyContacts/{contactId} {
          allow read, write: if isOwner(userId);
          allow read: if isSignedIn() && exists(/databases/$(database)/documents/users/$(userId)/properties/$(propertyId)/tenants/$(request.auth.uid));
        }
        
        match /inspections/{inspectionId} {
          allow read, write: if isOwner(userId);
        }
      }
    }

    // --- TOP-LEVEL VAULT ---

    match /documents/{documentId} {
      allow read, write: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        resource.data.uploadedByUserId == request.auth.uid ||
        resource.data.tenantUserProfileId == request.auth.uid
      );
      allow create: if isSignedIn();
    }
  }
}
