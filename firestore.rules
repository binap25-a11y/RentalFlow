
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(landlordId) {
      return isSignedIn() && request.auth.uid == landlordId;
    }

    function isTenant(tenantId) {
      return isSignedIn() && request.auth.uid == tenantId;
    }

    function isMember(memberIds) {
      return isSignedIn() && memberIds != null && request.auth.uid in memberIds;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /properties/{id} {
      allow list: if isSignedIn() && (resource.data.landlordId == request.auth.uid || isMember(resource.data.memberIds));
      allow read: if isSignedIn() && (resource.data.landlordId == request.auth.uid || isMember(resource.data.memberIds));
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    match /tenantProfiles/{id} {
      allow list: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.userId == request.auth.uid || isMember(resource.data.memberIds));
      allow read: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.userId == request.auth.uid || isMember(resource.data.memberIds));
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.userId == request.auth.uid);
    }

    match /documents/{id} {
      allow list: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.userId == request.auth.uid || isMember(resource.data.memberIds));
      allow read: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.userId == request.auth.uid || isMember(resource.data.memberIds));
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.userId == request.auth.uid);
    }

    match /maintenanceRequests/{id} {
      allow list: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.tenantId == request.auth.uid || isMember(resource.data.memberIds));
      allow read: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.tenantId == request.auth.uid || isMember(resource.data.memberIds));
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.tenantId == request.auth.uid);
    }

    match /inspections/{id} {
      allow list: if isSignedIn() && (resource.data.landlordId == request.auth.uid || isMember(resource.data.memberIds));
      allow read: if isSignedIn() && (resource.data.landlordId == request.auth.uid || isMember(resource.data.memberIds));
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }
  }
}
