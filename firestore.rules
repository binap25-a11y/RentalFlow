
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(landlordId) {
      return isSignedIn() && request.auth.uid == landlordId;
    }

    function isMember(data) {
      return isSignedIn() && (
        data.landlordId == request.auth.uid || 
        data.tenantId == request.auth.uid || 
        data.userId == request.auth.uid ||
        (data.memberIds != null && request.auth.uid in data.memberIds) ||
        (data.tenantIds != null && request.auth.uid in data.tenantIds)
      );
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /properties/{id} {
      allow list: if isSignedIn() && (resource.data.landlordId == request.auth.uid || (resource.data.tenantIds != null && request.auth.uid in resource.data.tenantIds));
      allow read: if isSignedIn() && isMember(resource.data);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    match /tenantProfiles/{id} {
      allow list: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.userId == request.auth.uid);
      allow read: if isSignedIn() && isMember(resource.data);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.userId == request.auth.uid);
    }

    match /documents/{id} {
      allow list: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.userId == request.auth.uid || (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds));
      allow read: if isSignedIn() && isMember(resource.data);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.userId == request.auth.uid);
    }

    match /maintenanceRequests/{id} {
      allow list: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.tenantId == request.auth.uid || (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds));
      allow read: if isSignedIn() && isMember(resource.data);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.tenantId == request.auth.uid);
    }

    match /inspections/{id} {
      allow list: if isSignedIn() && (resource.data.landlordId == request.auth.uid || (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds));
      allow read: if isSignedIn() && isMember(resource.data);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }
  }
}
