rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // User profiles: Only the owner can read/write
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Properties and their sub-resources
      // This match allows listing the /users/{userId}/properties collection
      match /properties/{propertyId} {
        
        function isLandlord() {
          return isSignedIn() && request.auth.uid == userId;
        }

        // Allow list if you are the landlord of this path
        allow list: if isLandlord();
        
        // Standard read for single docs: Landlord or Member
        allow get: if isLandlord() || (isSignedIn() && resource.data.members[request.auth.uid] != null);

        allow create: if isLandlord();
        allow update, delete: if isLandlord();

        // Sub-collections nested under properties
        match /tenantProfiles/{id} { 
          allow read: if isLandlord() || (isSignedIn() && (resource.data.userId == request.auth.uid));
          allow write: if isLandlord(); 
        }
        match /images/{id} { 
          allow read: if isLandlord() || (isSignedIn() && resource.data.members[request.auth.uid] != null); 
          allow write: if isLandlord(); 
        }
        match /documents/{id} { 
          allow read: if isLandlord() || (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.members[request.auth.uid] != null)); 
          allow write: if isLandlord(); 
        }
        match /inspections/{id} { 
          allow read: if isLandlord() || (isSignedIn() && resource.data.members[request.auth.uid] != null); 
          allow write: if isLandlord(); 
        }
        match /maintenanceRequests/{id} { 
          allow read: if isLandlord() || (isSignedIn() && (resource.data.tenantId == request.auth.uid || resource.data.landlordId == request.auth.uid)); 
          allow create: if isSignedIn();
          allow update, delete: if isLandlord() || (isSignedIn() && resource.data.tenantId == request.auth.uid);
        }
        match /emergencyContactSheets/{id} { 
          allow read: if isLandlord() || (isSignedIn() && resource.data.members[request.auth.uid] != null); 
          allow write: if isLandlord(); 
        }
        match /emergencyContacts/{id} { 
          allow read: if isLandlord() || (isSignedIn() && resource.data.members[request.auth.uid] != null); 
          allow write: if isLandlord(); 
        }
      }
    }

    // Collection Group rules for cross-property queries
    // These require landlordId or tenantId filters in the query
    match /{path=**}/properties/{id} {
      allow list: if isSignedIn() && (
        query.limit <= 100 && (
          request.auth.uid == resource.data.landlordId || 
          resource.data.members[request.auth.uid] != null
        )
      );
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
    match /{path=**}/maintenanceRequests/{id} {
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
    }
    match /{path=**}/inspections/{id} {
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
    match /{path=**}/tenantProfiles/{id} {
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
    }
    match /{path=**}/documents/{id} {
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
  }
}
