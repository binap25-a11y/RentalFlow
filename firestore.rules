
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Properties: Secured by landlordId or membership
    match /properties/{id} {
      allow read, list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds) ||
        (resource.data.tenantIds != null && request.auth.uid in resource.data.tenantIds)
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // Tenant Profiles
    match /tenantProfiles/{id} {
      allow read, list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // Documents
    match /documents/{id} {
      allow read, list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // Maintenance Requests
    match /maintenanceRequests/{id} {
      allow read, list, update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid ||
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow create: if isSignedIn();
    }

    // Inspections
    match /inspections/{id} {
      allow read, list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // Messages: Using membership array for robust listing
    match /messages/{id} {
      allow read, list: if isSignedIn() && (
        resource.data.memberIds != null && request.auth.uid in resource.data.memberIds
      );
      allow create: if isSignedIn() && (
        request.resource.data.memberIds != null && request.auth.uid in request.resource.data.memberIds
      );
      allow delete: if isSignedIn() && (
        resource.data.memberIds != null && request.auth.uid in resource.data.memberIds
      );
    }
  }
}
