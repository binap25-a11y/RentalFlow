rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    
    match /properties/{propertyId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.landlordId || 
        request.auth.uid in resource.data.memberIds || 
        request.auth.uid in resource.data.tenantIds
      );
      allow write: if isSignedIn() && request.auth.uid == resource.data.landlordId;
      allow create: if isSignedIn();
    }
    
    match /maintenanceRequests/{requestId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.landlordId || 
        request.auth.uid in resource.data.memberIds
      );
      allow write, create: if isSignedIn();
    }
    
    match /tenantProfiles/{profileId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.landlordId || 
        request.auth.uid == resource.data.userId || 
        request.auth.uid in resource.data.memberIds
      );
      allow write, create: if isSignedIn();
    }

    match /documents/{id} { 
      allow read: if isSignedIn() && (request.auth.uid in resource.data.memberIds);
      allow write: if isSignedIn() && (request.auth.uid == resource.data.landlordId);
      allow create: if isSignedIn();
    }
    
    match /messages/{id} { 
      allow read: if isSignedIn() && (request.auth.uid in resource.data.memberIds);
      allow write, create: if isSignedIn();
    }
    
    match /inspections/{id} { 
      allow read: if isSignedIn() && (request.auth.uid in resource.data.memberIds);
      allow write, create: if isSignedIn();
    }
    
    match /emergencyContacts/{id} { 
      allow read: if isSignedIn() && (request.auth.uid in resource.data.memberIds);
      allow write, create: if isSignedIn();
    }
  }
}
