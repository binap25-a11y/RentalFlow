rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /properties/{propertyId} {
        function propertyIsOwner() {
          return isOwner(userId);
        }
        
        function propertyIsMember() {
          return isSignedIn() && (
            (resource != null && resource.data.members != null && resource.data.members[request.auth.uid] != null) ||
            (request.resource != null && request.resource.data.members != null && request.resource.data.members[request.auth.uid] != null)
          );
        }

        allow read: if propertyIsOwner() || propertyIsMember();
        allow write: if propertyIsOwner();

        match /{allSubcollections=**} {
          allow read, write: if propertyIsOwner();
          allow read: if isSignedIn() && (
            resource != null && (
              resource.data.userId == request.auth.uid ||
              resource.data.tenantId == request.auth.uid ||
              resource.data.landlordId == request.auth.uid ||
              (resource.data.members != null && resource.data.members[request.auth.uid] != null)
            )
          );
        }
      }
    }

    match /{path=**}/properties/{id} {
      allow list: if isSignedIn() && (
        (resource.data.landlordId == request.auth.uid) || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
    match /{path=**}/maintenanceRequests/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
    }
    match /{path=**}/inspections/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
    match /{path=**}/tenantProfiles/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
    }
    match /{path=**}/documents/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
    match /{path=**}/emergencyContactSheets/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
  }
}