
/**
 * RentalFlow Security Rules
 * 
 * Core Philosophy:
 * Centered around Landlord ownership with data-based authorization to support
 * both hierarchical access and portfolio-wide Collection Group queries.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isUserInField(fieldName) {
      return isSignedIn() && fieldName in resource.data && resource.data[fieldName] == request.auth.uid;
    }

    // --- PORTFOLIO-WIDE (COLLECTION GROUP) RULES ---
    // These rules apply regardless of where the document is nested.

    match /{path=**}/maintenanceRequests/{requestId} {
      allow read: if isSignedIn() && (
        isUserInField('landlordId') || 
        isUserInField('reportedByUserId') || 
        isUserInField('assignedToUserId')
      );
      // Allow creation if the reporter is the authenticated user
      allow create: if isSignedIn() && request.resource.data.reportedByUserId == request.auth.uid;
      // Allow update if the user is the landlord or reporter or assigned
      allow update: if isSignedIn() && (
        isUserInField('landlordId') || 
        isUserInField('reportedByUserId') || 
        isUserInField('assignedToUserId')
      );
      allow delete: if isUserInField('landlordId');
    }

    match /{path=**}/tenants/{tenantId} {
      allow read: if isSignedIn() && (
        isUserInField('landlordId') || 
        isUserInField('userProfileId')
      );
      allow write: if isUserInField('landlordId');
    }

    match /{path=**}/emergencyContacts/{contactId} {
      allow read: if isSignedIn(); // Broad read for property context
      allow write: if isSignedIn(); // Authorized by parent property ownership
    }

    // --- HIERARCHICAL RULES ---

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
      
      match /properties/{propertyId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.landlordId == userId;
        allow update, delete: if isOwner(userId);

        // Inspections are usually handled within the property context
        match /inspections/{inspectionId} {
          allow read, write: if isOwner(userId);

          match /items/{itemId} {
            allow read, write: if isOwner(userId);
          }
        }
      }
    }

    // --- TOP-LEVEL DOCUMENTS (Vault) ---

    match /documents/{documentId} {
      allow read: if isSignedIn() && (
        isUserInField('uploadedByUserId') || 
        isUserInField('landlordId') || 
        isUserInField('tenantUserProfileId')
      );
      allow create: if isSignedIn() && request.resource.data.uploadedByUserId == request.auth.uid;
      allow update, delete: if isSignedIn() && (isUserInField('uploadedByUserId') || isUserInField('landlordId'));
    }
  }
}
