rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Standard User Profile Access
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Allow the owner full access to their own data tree recursively
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // Helper to check if user is a member of the property or the request
    function isPropertyParticipant(data) {
      return isSignedIn() && (
        data.landlordId == request.auth.uid || 
        data.userId == request.auth.uid ||
        data.tenantId == request.auth.uid ||
        (data.members != null && data.members[request.auth.uid] != null)
      );
    }

    // Collection Group Rules for Queries
    // These allow the list operations used in dashboards
    
    match /{path=**}/properties/{id} {
      allow list: if isSignedIn() && (
        request.query.limit <= 100 && (
          resource.data.landlordId == request.auth.uid || 
          (resource.data.members != null && resource.data.members[request.auth.uid] != null)
        )
      );
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }

    match /{path=**}/maintenanceRequests/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
    }

    match /{path=**}/inspections/{id} {
      allow list, read: if isPropertyParticipant(resource.data);
    }

    match /{path=**}/tenantProfiles/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
    }

    match /{path=**}/documents/{id} {
      allow list, read: if isPropertyParticipant(resource.data);
    }

    match /{path=**}/emergencyContactSheets/{id} {
      allow list, read: if isPropertyParticipant(resource.data);
    }
  }
}