rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // User profiles are private
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Properties: Shared with tenants via tenantIds or memberIds
    match /properties/{id} {
      allow list, read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds) ||
        (resource.data.tenantIds != null && request.auth.uid in resource.data.tenantIds)
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // Tenant Profiles: Explicitly allow listing for landlords and residents
    match /tenantProfiles/{id} {
      allow read, list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
    }

    // Documents: Secured by membership
    match /documents/{id} {
      allow list, read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
    }

    // Maintenance: Secured by membership
    match /maintenanceRequests/{id} {
      allow list, read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
    }

    // Inspections: Primarily for landlords, but allow reading if a member
    match /inspections/{id} {
      allow list, read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }
  }
}