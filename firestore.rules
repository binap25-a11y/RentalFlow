rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // User profiles: Only the owner can read/write
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Properties and their sub-resources nested under users
      match /properties/{propertyId} {
        
        function isOwner() {
          return isSignedIn() && request.auth.uid == userId;
        }

        function isTenant() {
          return isSignedIn() && resource != null && resource.data.members != null && resource.data.members[request.auth.uid] == 'tenant';
        }

        // Landlords (owners) have full access to their properties
        allow read, write: if isOwner();
        
        // Tenants can read properties they are members of
        allow get: if isTenant();

        // Sub-collections nested under properties
        match /tenantProfiles/{id} { 
          allow read: if isOwner() || (isSignedIn() && resource.data.userId == request.auth.uid);
          allow write: if isOwner(); 
        }
        match /images/{id} { 
          allow read: if isOwner() || isTenant(); 
          allow write: if isOwner(); 
        }
        match /documents/{id} { 
          allow read: if isOwner() || isTenant() || (isSignedIn() && resource.data.userId == request.auth.uid); 
          allow write: if isOwner(); 
        }
        match /inspections/{id} { 
          allow read: if isOwner() || isTenant(); 
          allow write: if isOwner(); 
        }
        match /maintenanceRequests/{id} { 
          allow read: if isOwner() || (isSignedIn() && (resource.data.tenantId == request.auth.uid || resource.data.landlordId == request.auth.uid)); 
          allow create: if isSignedIn();
          allow update, delete: if isOwner() || (isSignedIn() && resource.data.tenantId == request.auth.uid);
        }
        match /emergencyContactSheets/{id} { 
          allow read: if isOwner() || isTenant(); 
          allow write: if isOwner(); 
        }
        match /emergencyContacts/{id} { 
          allow read: if isOwner() || isTenant(); 
          allow write: if isOwner(); 
        }
      }
    }

    // Collection Group rules for cross-property queries
    match /{path=**}/properties/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
    match /{path=**}/maintenanceRequests/{id} {
      allow read, list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid ||
        resource.data.reportedByUserId == request.auth.uid
      );
    }
    match /{path=**}/inspections/{id} {
      allow read, list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
    match /{path=**}/tenantProfiles/{id} {
      allow read, list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
    }
    match /{path=**}/documents/{id} {
      allow read, list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
  }
}