rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // User profiles: Only the owner can read/write
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Properties and their sub-resources
      match /properties/{propertyId} {
        
        function isLandlord() {
          return isSignedIn() && request.auth.uid == userId;
        }
        
        function isMember() {
          return isSignedIn() && (
            isLandlord() || 
            (resource != null && resource.data.members != null && resource.data.members[request.auth.uid] != null) ||
            (request.resource != null && request.resource.data.members != null && request.resource.data.members[request.auth.uid] != null)
          );
        }

        allow read: if isMember();
        allow create: if isLandlord();
        allow update, delete: if isLandlord();

        // Sub-collections nested under properties
        match /tenantProfiles/{id} { 
          allow read: if isMember() || (isSignedIn() && resource.data.userId == request.auth.uid);
          allow write: if isLandlord(); 
        }
        match /images/{id} { allow read: if isMember(); allow write: if isLandlord(); }
        match /documents/{id} { 
          allow read: if isMember() || (isSignedIn() && resource.data.userId == request.auth.uid); 
          allow write: if isLandlord(); 
        }
        match /inspections/{id} { allow read: if isMember(); allow write: if isLandlord(); }
        match /maintenanceRequests/{id} { 
          allow read: if isMember() || (isSignedIn() && resource.data.tenantId == request.auth.uid); 
          allow create: if isSignedIn();
          allow update, delete: if isLandlord() || (isSignedIn() && resource.data.tenantId == request.auth.uid);
        }
        match /emergencyContactSheets/{id} { allow read: if isMember(); allow write: if isLandlord(); }
        match /emergencyContacts/{id} { allow read: if isMember(); allow write: if isLandlord(); }
      }
    }

    // Collection Group rules for cross-property queries used by landlords
    match /{path=**}/properties/{id} {
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
    match /{path=**}/maintenanceRequests/{id} {
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
    }
    match /{path=**}/inspections/{id} {
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
    match /{path=**}/tenantProfiles/{id} {
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
    }
    match /{path=**}/documents/{id} {
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
  }
}