rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return data.landlordId == request.auth.uid || data.tenantId == request.auth.uid;
    }

    function isMember(data) {
      return data.memberIds != null && request.auth.uid in data.memberIds;
    }

    // --- COLLECTION GROUP RULES ---
    
    // 1. Properties
    match /{path=**}/properties/{id} {
      allow list: if isSignedIn() && (
        request.query.where('landlordId', '==', request.auth.uid) ||
        request.query.where('memberIds', 'array-contains', request.auth.uid)
      );
      
      allow get: if isSignedIn() && (isOwner(resource.data) || isMember(resource.data));
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // 2. Documents
    match /{path=**}/documents/{id} {
      allow list: if isSignedIn() && (
        request.query.where('landlordId', '==', request.auth.uid) ||
        request.query.where('userId', '==', request.auth.uid) ||
        request.query.where('memberIds', 'array-contains', request.auth.uid)
      );
      
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        isMember(resource.data)
      );
      
      allow create, update, delete: if isSignedIn() && (
        request.resource == null || request.resource.data.landlordId == request.auth.uid
      );
    }

    // 3. Maintenance Requests
    match /{path=**}/maintenanceRequests/{id} {
      allow list: if isSignedIn() && (
        request.query.where('landlordId', '==', request.auth.uid) ||
        request.query.where('tenantId', '==', request.auth.uid)
      );
      
      allow get: if isSignedIn() && (isOwner(resource.data));
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (isOwner(resource.data));
    }

    // 4. Inspections
    match /{path=**}/inspections/{id} {
      allow list: if isSignedIn() && (
        request.query.where('landlordId', '==', request.auth.uid) ||
        request.query.where('memberIds', 'array-contains', request.auth.uid)
      );
      
      allow get: if isSignedIn() && (isOwner(resource.data) || isMember(resource.data));
      allow create, update, delete: if isSignedIn() && (
        request.resource == null || request.resource.data.landlordId == request.auth.uid
      );
    }

    // --- PATH-SPECIFIC RULES ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}