
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // -------------------------
    // USERS
    // -------------------------
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // -------------------------
    // DOCUMENTS
    // -------------------------
    match /documents/{docId} {
      allow create: if isSignedIn();
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Allow LIST with userId filter for security compliance
      allow list: if isSignedIn() && request.query.where("userId", "==", request.auth.uid);
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // -------------------------
    // PROPERTIES
    // -------------------------
    match /properties/{propertyId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      allow list: if isSignedIn(); // Filter applied in queries
    }

    // -------------------------
    // TENANTS
    // -------------------------
    match /tenants/{tenantId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.userProfileId == request.auth.uid);
      allow list: if isSignedIn(); // Filter applied in queries
    }

    // -------------------------
    // MAINTENANCE REQUESTS
    // -------------------------
    match /maintenanceRequests/{requestId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.reportedByUserId == request.auth.uid);
      allow list: if isSignedIn(); // Filter applied in queries
    }

    // -------------------------
    // EMERGENCY CONTACTS
    // -------------------------
    match /emergencyContacts/{contactId} {
      allow read, write: if isSignedIn();
    }

    // -------------------------
    // INSPECTIONS
    // -------------------------
    match /inspections/{inspectionId} {
      allow read, write: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      allow list: if isSignedIn();
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
