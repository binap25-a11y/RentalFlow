rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- COLLECTION GROUP RULES ---
    // Optimizing for query-rules alignment: splitting conditions into separate allow blocks.

    // 1. Properties
    match /{path=**}/properties/{id} {
      // Landlord access (list/get)
      allow list, get: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      // Member access (get only)
      allow get: if isSignedIn() && resource.data.members != null && resource.data.members[request.auth.uid] != null;
      
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // 2. Documents
    match /{path=**}/documents/{id} {
      // Landlord portfolio list/get
      allow list, get: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      // Tenant specific list/get
      allow list, get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create, update, delete: if isSignedIn() && (
        request.resource == null || request.resource.data.landlordId == request.auth.uid
      );
    }

    // 3. Maintenance Requests
    match /{path=**}/maintenanceRequests/{id} {
      // Landlord portfolio list/get
      allow list, get: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      // Tenant specific list/get
      allow list, get: if isSignedIn() && resource.data.tenantId == request.auth.uid;
      
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
    }

    // 4. Inspections
    match /{path=**}/inspections/{id} {
      allow list, get: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      
      allow create, update, delete: if isSignedIn() && (
        request.resource == null || request.resource.data.landlordId == request.auth.uid
      );
    }

    // 5. Tenant Profiles
    match /{path=**}/tenantProfiles/{id} {
      allow list, get: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      allow list, get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create, update, delete: if isSignedIn() && (
        request.resource == null || request.resource.data.landlordId == request.auth.uid
      );
    }

    // 6. Property Images
    match /{path=**}/images/{id} {
      allow list, get: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      allow create, delete: if isSignedIn() && (
        request.resource == null || request.resource.data.landlordId == request.auth.uid
      );
    }

    // 7. Emergency Contact Sheets
    match /{path=**}/emergencyContactSheets/{id} {
      allow list, get: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      allow create: if isSignedIn();
    }

    // --- PATH-SPECIFIC RULES ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
