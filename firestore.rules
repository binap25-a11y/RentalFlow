rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION GROUP RULES ---
    // For collectionGroup queries, we must allow 'list' if the user is signed in.
    // The query itself must be filtered by the client (e.g., where('landlordId', '==', uid)).
    // Individual document access ('get') is still strictly protected.

    match /{path=**}/properties/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    match /{path=**}/maintenanceRequests/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
    }

    match /{path=**}/documents/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    match /{path=**}/inspections/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      allow create, update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    match /{path=**}/tenantProfiles/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
      allow create, update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    match /{path=**}/images/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      allow create, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    match /{path=**}/emergencyContactSheets/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid ||
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
      allow create: if isSignedIn();
    }

    // --- PATH-SPECIFIC RULES ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}