rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Explicitly match top-level collections for reliable listing and querying
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /properties/{id} {
      allow read, write: if isSignedIn();
    }

    match /emergencyContacts/{id} {
      allow read, write: if isSignedIn();
    }

    match /tenantProfiles/{id} {
      allow read, write: if isSignedIn();
    }

    // Document Vault access logic
    match /documents/{id} {
      allow read, write: if isSignedIn();
    }

    match /maintenanceRequests/{id} {
      allow read, write: if isSignedIn();
    }

    match /inspections/{id} {
      allow read, write: if isSignedIn();
    }

    // Messaging Hub access logic
    match /messages/{id} {
      allow read, write: if isSignedIn();
    }

    // Recursive helper for nested structures if needed in future
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}