
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // User profiles: Only the owner can read/write
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Hierarchical Properties and all sub-collections
      match /properties/{propertyId} {
        function isOwner() {
          return isSignedIn() && request.auth.uid == userId;
        }
        
        function isMember() {
          return isSignedIn() && resource != null && resource.data.members != null && resource.data.members[request.auth.uid] != null;
        }

        allow read: if isOwner() || isMember();
        allow write: if isOwner();

        // Sub-collections (Nested)
        match /{allSubcollections=**} {
          allow read, write: if isOwner();
          allow read: if isSignedIn() && (
            (resource != null && (
              resource.data.userId == request.auth.uid ||
              resource.data.tenantId == request.auth.uid ||
              resource.data.landlordId == request.auth.uid ||
              (resource.data.members != null && resource.data.members[request.auth.uid] != null)
            ))
          );
        }
      }
    }

    // Collection Group rules (Required for portfolio-wide and cross-property queries)
    match /{path=**}/properties/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
    match /{path=**}/maintenanceRequests/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
    }
    match /{path=**}/inspections/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
    match /{path=**}/tenantProfiles/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
    }
    match /{path=**}/documents/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
    match /{path=**}/emergencyContactSheets/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
  }
}
