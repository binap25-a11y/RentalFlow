rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /properties/{propertyId} {
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
      allow create: if isSignedIn() && request.resource.data.landlordId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }
    
    match /tenants/{tenantId} {
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        resource.data.userProfileId == request.auth.uid
      );
      allow write: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }
    
    match /maintenanceRequests/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.reportedByUserId == request.auth.uid ||
        resource.data.tenantId == request.auth.uid
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.reportedByUserId == request.auth.uid
      );
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    match /inspections/{inspectionId} {
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
      allow write: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    match /documents/{documentId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.landlordId == request.auth.uid
      );
      allow write: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.landlordId == request.auth.uid
      );
    }
    
    match /emergencyContacts/{contactId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }
  }
}