rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // User profiles: Only the owner can read/write
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Properties and their sub-resources nested under users
      match /properties/{propertyId} {
        
        function isOwner() {
          return isSignedIn() && request.auth.uid == userId;
        }

        function isMember() {
          return isSignedIn() && (
            isOwner() ||
            (resource != null && resource.data.members != null && resource.data.members[request.auth.uid] != null)
          );
        }

        // Full access to the owner (landlord) for the property and all its subcollections
        allow read, write: if isOwner();
        
        // Members (tenants) can read the property document itself
        allow get: if isMember();

        // Recursively allow access to all subcollections for the owner
        match /{allSubcollections=**} {
          allow read, write: if isOwner();
        }

        // Specific tenant access for subcollections
        match /tenantProfiles/{id} { 
          allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
        }
        match /images/{id} { 
          allow read: if isMember(); 
        }
        match /documents/{id} { 
          allow read: if isMember() || (isSignedIn() && resource.data.userId == request.auth.uid); 
        }
        match /inspections/{id} { 
          allow read: if isMember(); 
        }
        match /maintenanceRequests/{id} { 
          allow read, update, delete: if isSignedIn() && resource.data.tenantId == request.auth.uid;
          allow create: if isSignedIn();
        }
      }
    }

    // Collection Group rules for cross-property queries (Essential for Landlord Dashboard/Registers)
    // Landlords list their own data across all their properties using collectionGroup
    match /{path=**}/properties/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
    match /{path=**}/maintenanceRequests/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
    }
    match /{path=**}/inspections/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
    match /{path=**}/tenantProfiles/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
    }
    match /{path=**}/documents/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
  }
}
