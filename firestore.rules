rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global permissive rules for authenticated users to ensure listing and sub-collection queries work
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Explicit path matching for top-level collections to satisfy security engine for direct lookups
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /properties/{id} {
      allow read, write: if request.auth != null;
    }

    match /documents/{id} {
      allow read, write: if request.auth != null;
    }

    match /messages/{id} {
      allow read, write: if request.auth != null;
    }

    match /maintenanceRequests/{id} {
      allow read, write: if request.auth != null;
    }

    match /inspections/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /tenantProfiles/{id} {
      allow read, write: if request.auth != null;
    }

    match /emergencyContacts/{id} {
      allow read, write: if request.auth != null;
    }
  }
}