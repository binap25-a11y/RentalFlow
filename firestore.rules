
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Check if the current user is a tenant assigned to a specific property
    function isTenantOfProperty(landlordId, propertyId) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(landlordId)/properties/$(propertyId)/tenants/$(request.auth.uid));
    }

    // --- COLLECTION GROUP RULES ---

    match /{path=**}/maintenanceRequests/{requestId} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.reportedByUserId == request.auth.uid
      );
      
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.reportedByUserId == request.auth.uid
      );
      
      allow create: if isSignedIn() && request.resource.data.reportedByUserId == request.auth.uid;
      
      allow update: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.reportedByUserId == request.auth.uid
      );
      
      allow delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    match /{path=**}/tenants/{tenantId} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        ("userProfileId" in resource.data && resource.data.userProfileId == request.auth.uid) ||
        tenantId == request.auth.uid
      );
      
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        ("userProfileId" in resource.data && resource.data.userProfileId == request.auth.uid) ||
        tenantId == request.auth.uid
      );
      
      allow write: if isSignedIn() && (
        (exists(resource) && resource.data.landlordId == request.auth.uid) ||
        (!exists(resource) && request.resource.data.landlordId == request.auth.uid)
      );
    }

    match /{path=**}/emergencyContacts/{contactId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- HIERARCHICAL RULES ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update, delete: if isOwner(userId);
      
      match /properties/{propertyId} {
        allow list: if isOwner(userId);
        allow get: if isSignedIn() && (
          isOwner(userId) || 
          exists(/databases/$(database)/documents/users/$(userId)/properties/$(propertyId)/tenants/$(request.auth.uid))
        );
        allow create: if isOwner(userId) && request.resource.data.landlordId == userId;
        allow update, delete: if isOwner(userId);

        match /inspections/{inspectionId} {
          allow read, write: if isOwner(userId);
        }
      }
    }

    // --- TOP-LEVEL VAULT ---

    match /documents/{documentId} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.uploadedByUserId == request.auth.uid || 
        ("tenantUserProfileId" in resource.data && resource.data.tenantUserProfileId == request.auth.uid)
      );
      
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.uploadedByUserId == request.auth.uid || 
        ("tenantUserProfileId" in resource.data && resource.data.tenantUserProfileId == request.auth.uid)
      );
      
      allow create: if isSignedIn() && request.resource.data.uploadedByUserId == request.auth.uid;
      
      allow update, delete: if isSignedIn() && (
        resource.data.uploadedByUserId == request.auth.uid || 
        resource.data.landlordId == request.auth.uid
      );
    }
  }
}
