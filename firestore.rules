rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Utility functions for robust access control
    function isSignedIn() {
      return request.auth != null;
    }
    
    // User profiles are private to the individual owner
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
    
    // Properties: Accessible by landlord or any assigned member
    match /properties/{propertyId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.landlordId || 
        request.auth.uid in resource.data.memberIds || 
        request.auth.uid in resource.data.tenantIds
      );
      allow write: if isSignedIn() && request.auth.uid == resource.data.landlordId;
      allow create: if isSignedIn();
    }
    
    // Notifications: The primary real-time alert feed
    match /notifications/{notificationId} {
      // Explicitly allow list queries based on memberIds or userId to resolve permission denials
      allow list: if isSignedIn() && (
        request.auth.uid in resource.data.memberIds || 
        request.auth.uid == resource.data.userId
      );
      allow get: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid in resource.data.memberIds
      );
      allow write, create: if isSignedIn();
    }
    
    // Maintenance Requests: Collaborative repair tracking
    match /maintenanceRequests/{requestId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.landlordId || 
        request.auth.uid == resource.data.tenantId || 
        request.auth.uid in resource.data.memberIds
      );
      allow write, create: if isSignedIn();
    }
    
    // Tenant Profiles: Bridge between landlords and users
    match /tenantProfiles/{profileId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.landlordId || 
        request.auth.uid == resource.data.userId || 
        request.auth.uid in resource.data.memberIds
      );
      allow write, create: if isSignedIn();
    }

    // Default rules for other managed collections using membership pattern
    match /documents/{id} { allow read, write: if isSignedIn() && request.auth.uid in resource.data.memberIds; }
    match /messages/{id} { allow read, write: if isSignedIn() && request.auth.uid in resource.data.memberIds; }
    match /inspections/{id} { allow read, write: if isSignedIn() && request.auth.uid in resource.data.memberIds; }
    match /emergencyContacts/{id} { allow read, write: if isSignedIn() && request.auth.uid in resource.data.memberIds; }
  }
}