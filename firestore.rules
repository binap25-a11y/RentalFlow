rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return data.landlordId == request.auth.uid || 
             data.tenantId == request.auth.uid || 
             data.userId == request.auth.uid;
    }

    function isMember(data) {
      return data.memberIds != null && request.auth.uid in data.memberIds;
    }

    // --- COLLECTION GROUP RULES (Portfolio-wide listing) ---
    // Firestore requires split list rules for OR conditions to pass the static analyzer.
    
    // 1. Properties
    match /{path=**}/properties/{id} {
      allow get: if isSignedIn() && (isOwner(resource.data) || isMember(resource.data));
      // Split list rules for query analyzer compatibility
      allow list: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      allow list: if isSignedIn() && (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds);
      
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // 2. Documents
    match /{path=**}/documents/{id} {
      allow get: if isSignedIn() && (isOwner(resource.data) || isMember(resource.data));
      // Split list rules for query analyzer compatibility
      allow list: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds);
      
      allow create, update, delete: if isSignedIn() && (
        request.resource.data.landlordId == request.auth.uid ||
        request.resource.data.userId == request.auth.uid
      );
    }

    // 3. Maintenance Requests
    match /{path=**}/maintenanceRequests/{id} {
      allow get: if isSignedIn() && isOwner(resource.data);
      // Split list rules for query analyzer compatibility
      allow list: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.tenantId == request.auth.uid;
      
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && isOwner(resource.data);
    }

    // 4. Inspections
    match /{path=**}/inspections/{id} {
      allow get: if isSignedIn() && (isOwner(resource.data) || isMember(resource.data));
      // Split list rules for query analyzer compatibility
      allow list: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      allow list: if isSignedIn() && (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds);
      
      allow create, update, delete: if isSignedIn() && (
        request.resource.data.landlordId == request.auth.uid
      );
    }

    // 5. Tenant Profiles
    match /{path=**}/tenantProfiles/{id} {
      allow get: if isSignedIn() && (isOwner(resource.data) || isMember(resource.data));
      // Split list rules for query analyzer compatibility
      allow list: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create, update, delete: if isSignedIn() && (
        request.resource.data.landlordId == request.auth.uid
      );
    }

    // --- PATH-SPECIFIC RULES ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
