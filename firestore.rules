rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // User profiles: Only the owner can read/write
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Hierarchical access for Landlords
      // Match the properties collection and all its documents
      match /properties/{propertyId} {
        
        function isOwner() {
          return isSignedIn() && request.auth.uid == userId;
        }

        function isMember() {
          return isSignedIn() && (
            isOwner() ||
            (resource != null && resource.data.members != null && resource.data.members[request.auth.uid] != null)
          );
        }

        // Allow listing the properties collection and reading/writing individual properties
        allow list: if isOwner() || (isSignedIn() && resource.data.members[request.auth.uid] != null);
        allow get: if isMember();
        allow write: if isOwner();

        // Sub-collections under a property
        match /{allSubcollections=**} {
          allow read, write: if isOwner();
        }

        // Specific tenant access for sub-collections
        match /tenantProfiles/{id} { 
          allow read: if isSignedIn() && (isOwner() || resource.data.userId == request.auth.uid);
        }
        match /images/{id} { 
          allow read: if isMember(); 
        }
        match /documents/{id} { 
          allow read: if isMember() || (isSignedIn() && resource.data.userId == request.auth.uid); 
        }
        match /inspections/{id} { 
          allow read: if isMember(); 
        }
        match /maintenanceRequests/{id} { 
          allow read, update, delete: if isSignedIn() && (isOwner() || resource.data.tenantId == request.auth.uid);
          allow create: if isSignedIn();
        }
      }
    }

    // Collection Group rules for cross-property queries
    // These allow landlords to query all their resources across different properties
    match /{path=**}/properties/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
    match /{path=**}/maintenanceRequests/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
    }
    match /{path=**}/inspections/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
    match /{path=**}/tenantProfiles/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
    }
    match /{path=**}/documents/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
    }
  }
}