
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // User profiles are private
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Properties: Secured by landlordId or tenant membership
    match /properties/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.tenantIds != null && request.auth.uid in resource.data.tenantIds)
      );
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.tenantIds != null && request.auth.uid in resource.data.tenantIds)
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // Tenant Profiles: Direct ownership check for reliable listing
    match /tenantProfiles/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // Documents: Secured by landlordId or userId
    match /documents/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid ||
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // Maintenance: Secured by landlordId, tenantId or membership
    match /maintenanceRequests/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid ||
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow get, update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid ||
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow create: if isSignedIn();
    }

    // Inspections: Landlords and members
    match /inspections/{id} {
      allow list: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow get, update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow create: if isSignedIn();
    }

    // Messages: Private to members
    match /messages/{id} {
      allow read: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid ||
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow create: if isSignedIn();
      allow delete: if isSignedIn() && (
        resource.data.senderId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      );
    }
  }
}
