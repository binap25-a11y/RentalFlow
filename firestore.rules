rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- COLLECTION GROUP RULES ---
    // Splitting OR conditions into separate allow blocks is the most reliable way 
    // to satisfy the Firestore Collection Group query analyzer.

    // 1. Properties
    match /{path=**}/properties/{id} {
      allow list: if isSignedIn() && request.query.where('landlordId', '==', request.auth.uid);
      
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
      
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    // 2. Documents
    match /{path=**}/documents/{id} {
      // Split list rules for Landlords and Tenants
      allow list: if isSignedIn() && request.query.where('landlordId', '==', request.auth.uid);
      allow list: if isSignedIn() && request.query.where('userId', '==', request.auth.uid);
      
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
      
      allow create, update, delete: if isSignedIn() && (
        request.resource == null || request.resource.data.landlordId == request.auth.uid
      );
    }

    // 3. Maintenance Requests
    match /{path=**}/maintenanceRequests/{id} {
      allow list: if isSignedIn() && request.query.where('landlordId', '==', request.auth.uid);
      allow list: if isSignedIn() && request.query.where('tenantId', '==', request.auth.uid);
      
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
      
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
    }

    // 4. Inspections
    match /{path=**}/inspections/{id} {
      allow list: if isSignedIn() && request.query.where('landlordId', '==', request.auth.uid);
      allow get: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      
      allow create, update, delete: if isSignedIn() && (
        request.resource == null || request.resource.data.landlordId == request.auth.uid
      );
    }

    // 5. Tenant Profiles
    match /{path=**}/tenantProfiles/{id} {
      allow list: if isSignedIn() && request.query.where('landlordId', '==', request.auth.uid);
      allow list: if isSignedIn() && request.query.where('userId', '==', request.auth.uid);
      
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
      
      allow create, update, delete: if isSignedIn() && (
        request.resource == null || request.resource.data.landlordId == request.auth.uid
      );
    }

    // 6. Property Images
    match /{path=**}/images/{id} {
      allow list: if isSignedIn() && request.query.where('landlordId', '==', request.auth.uid);
      allow get: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      
      allow create, delete: if isSignedIn() && (
        request.resource == null || request.resource.data.landlordId == request.auth.uid
      );
    }

    // 7. Emergency Contact Sheets
    match /{path=**}/emergencyContactSheets/{id} {
      allow list: if isSignedIn() && request.query.where('landlordId', '==', request.auth.uid);
      allow get: if isSignedIn() && resource.data.landlordId == request.auth.uid;
      allow create: if isSignedIn();
    }

    // --- PATH-SPECIFIC RULES ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}