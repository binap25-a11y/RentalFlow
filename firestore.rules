rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    // --- COLLECTION GROUP RULES ---
    // Collection Group rules must be at the top level for queries like collectionGroup().
    // We use strict 'read' permissions which forces Firestore to validate query filters.

    match /{path=**}/properties/{id} {
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid
      );
    }

    match /{path=**}/documents/{id} {
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
      allow create, update, delete: if isSignedIn() && (
        request.resource == null || request.resource.data.landlordId == request.auth.uid
      );
    }

    match /{path=**}/maintenanceRequests/{id} {
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
    }

    match /{path=**}/inspections/{id} {
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid
      );
      allow create, update, delete: if isSignedIn() && (
        request.resource == null || request.resource.data.landlordId == request.auth.uid
      );
    }

    match /{path=**}/tenantProfiles/{id} {
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
      allow create, update, delete: if isSignedIn() && (
        request.resource == null || request.resource.data.landlordId == request.auth.uid
      );
    }

    match /{path=**}/images/{id} {
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid
      );
      allow create, delete: if isSignedIn() && (
        request.resource == null || request.resource.data.landlordId == request.auth.uid
      );
    }

    match /{path=**}/emergencyContactSheets/{id} {
      allow read: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid
      );
      allow create: if isSignedIn();
    }

    // --- PATH-SPECIFIC RULES ---
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
