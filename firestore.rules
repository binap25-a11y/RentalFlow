
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // -------------------------
    // DOCUMENTS
    // -------------------------
    match /documents/{docId} {
      // Create
      allow create: if isSignedIn();

      // Read single doc
      allow get: if isSignedIn() &&
        (resource.data.userId == request.auth.uid || resource.data.tenantUserProfileId == request.auth.uid);

      // Allow LIST with filter
      allow list: if isSignedIn() &&
        (request.query.where("userId", "==", request.auth.uid) || request.query.where("tenantUserProfileId", "==", request.auth.uid));

      // Update/Delete
      allow update, delete: if isSignedIn() &&
        resource.data.userId == request.auth.uid;
    }

    // -------------------------
    // PROPERTIES
    // -------------------------
    match /properties/{propertyId} {
      allow read, write: if isSignedIn();
    }

    // -------------------------
    // TENANTS
    // -------------------------
    match /tenants/{tenantId} {
      allow read, write: if isSignedIn();
    }

    // -------------------------
    // MAINTENANCE REQUESTS
    // -------------------------
    match /maintenanceRequests/{requestId} {
      allow read, write: if isSignedIn();
    }

    // -------------------------
    // EMERGENCY CONTACTS
    // -------------------------
    match /emergencyContacts/{contactId} {
      allow read, write: if isSignedIn();
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
