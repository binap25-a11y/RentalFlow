
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // -------------------------
    // USERS
    // -------------------------
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // -------------------------
    // DOCUMENTS
    // -------------------------
    match /documents/{docId} {
      // Allow create if user is signed in
      allow create: if isSignedIn();
      // Allow read/list if user is the owner OR the landlord
      // Firestore automatically translates this into query filters for list operations.
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.landlordId == request.auth.uid);
      // Allow update/delete if user is the owner
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid);
    }

    // -------------------------
    // PROPERTIES
    // -------------------------
    match /properties/{propertyId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.landlordId == request.auth.uid);
      allow update, delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid);
    }

    // -------------------------
    // TENANTS
    // -------------------------
    match /tenants/{tenantId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.userProfileId == request.auth.uid);
      allow update, delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid);
    }

    // -------------------------
    // MAINTENANCE REQUESTS
    // -------------------------
    match /maintenanceRequests/{requestId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.reportedByUserId == request.auth.uid);
      allow update, delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid);
    }

    // -------------------------
    // EMERGENCY CONTACTS
    // -------------------------
    match /emergencyContacts/{contactId} {
      allow read, write: if isSignedIn();
    }

    // -------------------------
    // INSPECTIONS
    // -------------------------
    match /inspections/{inspectionId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid);
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
