rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // User profiles: Only the owner can read/write
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      // Properties: Landlord (parent) or members (tenants)
      match /properties/{propertyId} {
        allow read: if isSignedIn() && (
          userId == request.auth.uid || 
          (resource.data.members != null && resource.data.members[request.auth.uid] != null)
        );
        allow create: if isSignedIn() && userId == request.auth.uid;
        allow update, delete: if isSignedIn() && userId == request.auth.uid;

        // Nested collections based on backend.json
        match /tenantProfiles/{id} { allow read, write: if isSignedIn() && (userId == request.auth.uid || resource.data.userId == request.auth.uid); }
        match /images/{id} { allow read, write: if isSignedIn() && (userId == request.auth.uid || (resource.data.members != null && resource.data.members[request.auth.uid] != null)); }
        match /documents/{id} { allow read, write: if isSignedIn() && (userId == request.auth.uid || (resource.data.members != null && resource.data.members[request.auth.uid] != null)); }
        match /inspections/{id} { allow read, write: if isSignedIn() && (userId == request.auth.uid || (resource.data.members != null && resource.data.members[request.auth.uid] != null)); }
        match /maintenanceRequests/{id} { allow read, write: if isSignedIn() && (userId == request.auth.uid || resource.data.tenantId == request.auth.uid); }
        match /emergencyContactSheets/{id} { allow read, write: if isSignedIn() && (userId == request.auth.uid || (resource.data.members != null && resource.data.members[request.auth.uid] != null)); }
        match /emergencyContacts/{id} { allow read, write: if isSignedIn() && (userId == request.auth.uid || (resource.data.members != null && resource.data.members[request.auth.uid] != null)); }
      }
    }

    // Allow tenants to read their profiles if referenced by email/uid at top level if needed
    // But per backend.json, everything is nested.
  }
}