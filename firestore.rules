rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global permissive rules for authenticated users to ensure listing and sub-collection queries work
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Explicit path matching for top-level collections to satisfy security engine for direct lookups
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /properties/{id} {
      allow read, write: if request.auth != null;
    }

    // Explicit documents rule to ensure reliable deletion and listing for portfolio management
    match /documents/{id} {
      allow read, write: if request.auth != null;
    }

