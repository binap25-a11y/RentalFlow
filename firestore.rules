rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- COLLECTION GROUP RULES ---
    // These rules are required for collectionGroup() queries used in dashboards and hubs.
    // We separate 'list' (initiating the query) from 'get' (accessing individual documents)
    // to satisfy Firestore's authorization requirements for cross-collection queries.

    match /{path=**}/properties/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        (resource.data.members != null && resource.data.members[request.auth.uid] != null)
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid
      );
    }

    match /{path=**}/documents/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
      allow create, update, delete: if isSignedIn() && (
        resource == null || resource.data.landlordId == request.auth.uid
      );
    }

    match /{path=**}/maintenanceRequests/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid
      );
    }

    match /{path=**}/inspections/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid
      );
      allow create, update, delete: if isSignedIn() && (
        resource == null || resource.data.landlordId == request.auth.uid
      );
    }

    match /{path=**}/tenantProfiles/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
      allow create, update, delete: if isSignedIn() && (
        resource == null || resource.data.landlordId == request.auth.uid
      );
    }

    match /{path=**}/images/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid
      );
      allow create, delete: if isSignedIn() && (
        resource == null || resource.data.landlordId == request.auth.uid
      );
    }

    match /{path=**}/emergencyContactSheets/{id} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid
      );
      allow create: if isSignedIn();
    }

    // --- PATH-SPECIFIC RULES ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}