
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /{document=**} {
      allow read, write: if isSignedIn();
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /notifications/{id} {
      allow read, update: if isSignedIn() && request.auth.uid in resource.data.memberIds;
      allow create: if isSignedIn();
    }

    match /properties/{id} {
      allow read, write: if isSignedIn();
    }

    match /documents/{id} {
      allow read, write: if isSignedIn();
    }

    match /maintenanceRequests/{id} {
      allow read, list, update, delete: if isSignedIn() && (
        resource.data.landlordId == request.auth.uid || 
        resource.data.tenantId == request.auth.uid ||
        (resource.data.memberIds != null && request.auth.uid in resource.data.memberIds)
      );
      allow create: if isSignedIn();
    }

    match /messages/{id} {
      allow create: if isSignedIn();
      allow read, list: if isSignedIn() && (
        request.auth.uid in resource.data.memberIds
      );
      allow update, delete: if isSignedIn() && (
        resource.data.senderId == request.auth.uid
      );
    }
  }
}
