rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Explicitly for listing based on standardized fields
    // This allows Firestore to prove the query is safe.
    function canList(data) {
      return isSignedIn() && (
        data.landlordId == request.auth.uid ||
        data.tenantId == request.auth.uid ||
        data.userId == request.auth.uid ||
        (data.tenantIds != null && request.auth.uid in data.tenantIds) ||
        (data.memberIds != null && request.auth.uid in data.memberIds)
      );
    }

    // For individual read/write based on membership
    function isMember(data) {
      return isSignedIn() && (
        data.landlordId == request.auth.uid || 
        data.tenantId == request.auth.uid || 
        data.userId == request.auth.uid ||
        (data.memberIds != null && request.auth.uid in data.memberIds) ||
        (data.tenantIds != null && request.auth.uid in data.tenantIds)
      );
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /properties/{id} {
      allow list: if canList(resource.data);
      allow read: if isMember(resource.data);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }

    match /tenantProfiles/{id} {
      allow list: if canList(resource.data);
      allow read: if isMember(resource.data);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.userId == request.auth.uid);
    }

    match /documents/{id} {
      allow list: if canList(resource.data);
      allow read: if isMember(resource.data);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.userId == request.auth.uid);
    }

    match /maintenanceRequests/{id} {
      allow list: if canList(resource.data);
      allow read: if isMember(resource.data);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.landlordId == request.auth.uid || resource.data.tenantId == request.auth.uid);
    }

    match /inspections/{id} {
      allow list: if canList(resource.data);
      allow read: if isMember(resource.data);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.landlordId == request.auth.uid;
    }
  }
}
