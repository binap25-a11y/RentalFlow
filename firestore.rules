rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Explicitly match top-level collections for reliable listing and querying
    // This follows the recommended fix for permission denied errors on top-level collections.
    
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /properties/{id} {
      allow read, write: if isSignedIn();
    }

    match /emergencyContacts/{id} {
      allow read, write: if isSignedIn();
    }

    match /tenantProfiles/{id} {
      allow read, write: if isSignedIn();
    }

    match /documents/{id} {
      allow read, write: if isSignedIn();
    }

    match /maintenanceRequests/{id} {
      allow read, write: if isSignedIn();
    }

    match /inspections/{id} {
      allow read, write: if isSignedIn();
    }

    match /messages/{id} {
      allow read, write: if isSignedIn();
    }

    // Catch-all for recursive structures
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}